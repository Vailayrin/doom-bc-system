{
  "id": "doom-bc",
  "title": "Doom BC System",
  "description": "Foundry VTT v13 game system for Doom BC.",
  "version": "0.0.1",
  "authors": [
    {
      "name": "Doom BC Team"
    }
  ],
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "esmodules": [
    "scripts/doom-bc-system.js"
  ],
  "styles": [
    "styles/doom-bc-system.css"
  ],
  "languages": [
    {
      "lang": "ru",
      "name": "Русский",
      "path": "lang/ru.json"
    },
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": [
      "pc",
      "npc",
      "vehicle"
    ],
    "Item": [
      "rangedWeapon",
      "meleeWeapon",
      "armour",
      "ammunition",
      "artifact",
      "implant",
      "grenade",
      "talent",
      "trait",
      "psychicPower",
      "technoWonder"
    ]
  },
  "packs": [
    {
      "name": "items",
      "label": "Doom BC: Items",
      "path": "packs/items",
      "type": "Item",
      "system": "doom-bc"
    },
    {
      "name": "talents",
      "label": "Doom BC: Talents",
      "path": "packs/talents",
      "type": "Item",
      "system": "doom-bc"
    },
    {
      "name": "traits",
      "label": "Doom BC: Traits",
      "path": "packs/traits",
      "type": "Item",
      "system": "doom-bc"
    },
    {
      "name": "powers",
      "label": "Doom BC: Powers",
      "path": "packs/powers",
      "type": "Item",
      "system": "doom-bc"
    },
    {
      "name": "npc",
      "label": "Doom BC: NPC",
      "path": "packs/npc",
      "type": "Actor",
      "system": "doom-bc"
    },
    {
      "name": "vehicles",
      "label": "Doom BC: Vehicles",
      "path": "packs/vehicles",
      "type": "Actor",
      "system": "doom-bc"
    }
  ],
  "socket": false,
  "initiative": "@system.combat.initiative.die + @system.combat.initiative.flatBonus + @system.combat.initiative.actorMod"
}
