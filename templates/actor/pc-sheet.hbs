<form class="doom-bc-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'DOOMBC.ActorName'}}" /></h1>
      <p>{{localize "DOOMBC.ActorType.pc"}}</p>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="main">{{localize "DOOMBC.Tab.main"}}</a>
    <a class="item" data-tab="combat">{{localize "DOOMBC.Tab.combat"}}</a>
    <a class="item" data-tab="gear">{{localize "DOOMBC.Tab.gear"}}</a>
    <a class="item" data-tab="psychic">{{localize "DOOMBC.Tab.psychic"}}</a>
    <a class="item" data-tab="techno">{{localize "DOOMBC.Tab.techno"}}</a>
    <a class="item" data-tab="advancement">{{localize "DOOMBC.Tab.advancement"}}</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="main">
      <section class="identity-grid">
        {{#each identityFields as |field|}}
          <label class="field">
            <span>{{field.label}}</span>
            <input type="text" name="system.identity.{{field.key}}.value" value="{{field.value}}" />
            <input type="hidden" name="system.identity.{{field.key}}.id" value="{{field.id}}" />
          </label>
        {{/each}}
      </section>

      <section class="characteristics-section">
        <h2>{{localize "DOOMBC.Characteristics.title"}}</h2>
        <table class="characteristics-table">
          <thead>
            <tr>
              <th>{{localize "DOOMBC.Characteristics.characteristic"}}</th>
              <th>{{localize "DOOMBC.Characteristics.initial"}}</th>
              <th>{{localize "DOOMBC.Characteristics.advances"}}</th>
              <th>{{localize "DOOMBC.Characteristics.modifier"}}</th>
              <th>{{localize "DOOMBC.Characteristics.current"}}</th>
              <th>{{localize "DOOMBC.Characteristics.unnatural"}}</th>
              <th>{{localize "DOOMBC.Characteristics.bonus"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each characteristics as |char|}}
              <tr data-characteristic="{{char.key}}">
                <td>
                  <button
                    type="button"
                    class="char-roll-button"
                    data-action="roll-characteristic"
                    data-characteristic="{{char.key}}">
                    {{char.shortLabel}}
                  </button>
                  <span class="char-long-name">{{char.longLabel}}</span>
                </td>
                <td>
                  <input
                    type="number"
                    name="system.characteristics.{{char.key}}.initial"
                    value="{{char.initial}}"
                    min="0"
                    max="100"
                    data-char-field="initial" />
                </td>
                <td>
                  <input
                    type="number"
                    name="system.characteristics.{{char.key}}.advances"
                    value="{{char.advances}}"
                    min="0"
                    max="100"
                    data-char-field="advances" />
                </td>
                <td>
                  <input
                    type="number"
                    name="system.characteristics.{{char.key}}.modifier"
                    value="{{char.modifier}}"
                    min="-100"
                    max="100"
                    data-char-field="modifier" />
                </td>
                <td>
                  <input type="number" value="{{char.current}}" readonly data-derived="current" />
                </td>
                <td>
                  <input
                    type="number"
                    name="system.characteristics.{{char.key}}.unnatural"
                    value="{{char.unnatural}}"
                    min="0"
                    {{#unless @root.isGM}}readonly{{/unless}}
                    data-char-field="unnatural" />
                </td>
                <td>
                  <input type="number" value="{{char.bonus}}" readonly data-derived="bonus" />
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </section>
    </div>
    <div class="tab" data-group="primary" data-tab="combat">
      <p>{{localize "DOOMBC.Placeholder.phase0"}}</p>
    </div>
    <div class="tab" data-group="primary" data-tab="gear">
      <p>{{localize "DOOMBC.Placeholder.phase0"}}</p>
    </div>
    <div class="tab" data-group="primary" data-tab="psychic">
      <p>{{localize "DOOMBC.Placeholder.phase0"}}</p>
    </div>
    <div class="tab" data-group="primary" data-tab="techno">
      <p>{{localize "DOOMBC.Placeholder.phase0"}}</p>
    </div>
    <div class="tab" data-group="primary" data-tab="advancement">
      <p>{{localize "DOOMBC.Placeholder.phase0"}}</p>
    </div>
  </section>
</form>
