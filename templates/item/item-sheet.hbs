<form class="doom-bc-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      {{#if isTrait}}
        <h1>{{item.name}}</h1>
      {{else}}
        {{#if isTalent}}
          <h1>{{item.name}}</h1>
        {{else}}
          <h1><input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'DOOMBC.ItemName'}}" /></h1>
        {{/if}}
      {{/if}}
      <p>{{item.type}}</p>
    </div>
  </header>

  <section class="sheet-body">
    {{#if isTrait}}
      <section class="sheet-panel">
        <table class="compact-table">
          <tbody>
            <tr>
              <th>Name</th>
              <td><input type="text" name="name" value="{{item.name}}" /></td>
            </tr>
            <tr>
              <th>Rating</th>
              <td><input type="number" name="system.rating" value="{{system.rating}}" min="0" /></td>
            </tr>
            <tr>
              <th>Description</th>
              <td><textarea name="system.description" rows="6">{{system.description}}</textarea></td>
            </tr>
          </tbody>
        </table>
      </section>
    {{else}}
      {{#if isTalent}}
        <section class="sheet-panel">
          <table class="compact-table">
            <tbody>
              <tr>
                <th>Aptitude 1</th>
                <td>
                  <select name="system.aptitudes.first">
                    {{selectOptions talentAptitudeFirstOptions selected=system.aptitudes.first nameAttr="value" labelAttr="label"}}
                  </select>
                </td>
              </tr>
              <tr>
                <th>Aptitude 2</th>
                <td>
                  <select name="system.aptitudes.second">
                    {{selectOptions talentAptitudeSecondOptions selected=system.aptitudes.second nameAttr="value" labelAttr="label"}}
                  </select>
                </td>
              </tr>
              <tr>
                <th>Tier</th>
                <td>
                  <select name="system.tier">
                    {{selectOptions talentTierOptions selected=system.tier nameAttr="value" labelAttr="label"}}
                  </select>
                </td>
              </tr>
              <tr>
                <th>God</th>
                <td><input type="text" name="system.god" value="{{system.god}}" placeholder="Неделимый" /></td>
              </tr>
              <tr>
                <th>Requirements</th>
                <td><input type="text" name="system.requirements" value="{{system.requirements}}" placeholder="Нет" /></td>
              </tr>
              <tr>
                <th>Description</th>
                <td><textarea name="system.description" rows="6">{{system.description}}</textarea></td>
              </tr>
            </tbody>
          </table>
        </section>
      {{else}}
        <p>{{localize "DOOMBC.Placeholder.phase0"}}</p>
      {{/if}}
    {{/if}}
  </section>
</form>
